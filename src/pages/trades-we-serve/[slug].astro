---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import Button from "../../components/ui/Button.astro";
import CTA from "../../components/layout/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const allTrades = await getCollection("trades");

    return allTrades.map((trade) => ({
        params: { slug: trade.data.slug },
        props: { trade: trade.data },
    }));
}

const { trade } = Astro.props;

// Get all templates for this trade
const allTemplates = await getCollection("templates");
const tradeTemplates = allTemplates.filter(
    (template) => template.data.trade === trade.slug,
);
---

<BaseLayout
    title={`${trade.name} | Your Company`}
    description={trade.hoverDescription}
>
    <Hero2
        title={trade.name}
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE", href: "/trades-we-serve" },
            { label: trade.name.toUpperCase() },
        ]}
    />

    <!-- Stats Bar -->
    <section class="py-12 px-6 bg-primary border-b">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div>
                    <div
                        class="text-4xl font-heading font-bold text-accent mb-2"
                    >
                        500+
                    </div>
                    <div
                        class="text-base text-white font-heading font-bold uppercase"
                    >
                        Projects Completed
                    </div>
                </div>
                <div>
                    <div
                        class="text-4xl font-heading font-bold text-accent mb-2"
                    >
                        98%
                    </div>
                    <div
                        class="text-base text-white font-heading font-bold uppercase"
                    >
                        Customer Satisfaction
                    </div>
                </div>
                <div>
                    <div
                        class="text-4xl font-heading font-bold text-accent mb-2"
                    >
                        {tradeTemplates.length}
                    </div>
                    <div
                        class="text-base text-white font-heading font-bold uppercase"
                    >
                        Website Templates Available
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Templates Section -->
    {
        tradeTemplates.length > 0 && (
            <section class="py-16 px-6 bg-background">
                <div class="max-w-7xl mx-auto">
                    <div class="text-center mb-12">
                        <span class="inline-block px-4 py-2 bg-accent/10 text-accent font-heading font-bold uppercase text-sm mb-4">
                            Website Templates
                        </span>
                        <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                            Ready-to-Launch {trade.name} Websites
                        </h2>
                        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                            Choose from our professionally designed templates.
                            Each one is mobile-optimized and built to convert
                            visitors into customers.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {tradeTemplates.map((template) => (
                            <a
                                href={template.data.liveDemoUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="bg-white shadow-md hover:shadow-xl transition-all duration-300 group block"
                            >
                                {/* Template Preview */}
                                <div class="relative h-64 overflow-hidden bg-gray-200">
                                    <div class="absolute top-4 right-4 z-10">
                                        <span class="bg-accent text-white px-3 py-1 text-xs font-heading font-bold uppercase">
                                            {template.data.category}
                                        </span>
                                    </div>
                                    <img
                                        src={template.data.thumbnail}
                                        alt={template.data.title}
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                    />

                                    {/* Hover Overlay */}
                                    <div class="absolute inset-0 bg-gradient-to-b from-primary/90 to-primary/95 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                                        <div class="text-center px-6">
                                            <svg
                                                class="w-16 h-16 text-accent mx-auto mb-4"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                stroke-width="2"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                                />
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                                />
                                            </svg>
                                            <p class="text-white text-xl font-heading font-bold uppercase tracking-wide">
                                                View Demo
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {/* Template Info */}
                                <div class="p-6">
                                    <h3 class="text-xl font-heading font-bold text-primary mb-2 group-hover:text-accent transition-colors">
                                        {template.data.title}
                                    </h3>
                                    <p class="text-base text-gray-600 line-clamp-2">
                                        {template.data.description}
                                    </p>
                                </div>
                            </a>
                        ))}
                    </div>

                    {/* CTA to see all templates */}
                    <div class="text-center mt-12">
                        <p class="text-base text-gray-600 mb-4">
                            Want to see templates for other industries?
                        </p>
                        <Button variant="outline" size="md" href="/our-work">
                            Browse All Works
                        </Button>
                    </div>
                </div>
            </section>
        )
    }

    {
        tradeTemplates.length === 0 && (
            <section class="py-16 px-6 bg-background">
                <div class="max-w-4xl mx-auto text-center">
                    <div class="w-20 h-20 bg-accent/10 mx-auto mb-6 flex items-center justify-center">
                        <svg
                            class="w-10 h-10 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6v6m0 0v6m0-6h6m-6 0H6"
                            />
                        </svg>
                    </div>
                    <h2 class="text-3xl font-heading font-bold text-primary mb-4">
                        Templates Coming Soon
                    </h2>
                    <p class="text-xl text-gray-600 mb-8">
                        We're currently developing professional website
                        templates specifically for {trade.name.toLowerCase()}{" "}
                        businesses. In the meantime, check out our other
                        industry templates.
                    </p>
                    <Button variant="accent" size="md" href="/our-work">
                        View All Templates
                    </Button>
                </div>
            </section>
        )
    }

    <!-- Service Information Section -->
    <section class="py-20 px-6 bg-white">
        <div class="max-w-7xl mx-auto">
            <!-- Section Header -->
            <div class="text-center mb-16">
                <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                    Why Choose Our {trade.name} Services?
                </h2>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    {trade.hoverDescription}
                </p>
            </div>

            <!-- Features Grid -->
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16"
            >
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3
                        class="text-xl font-heading font-bold text-primary mb-2"
                    >
                        Licensed & Insured
                    </h3>
                    <p class="text-base text-gray-600">
                        Fully certified professionals you can trust
                    </p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3
                        class="text-xl font-heading font-bold text-primary mb-2"
                    >
                        24/7 Emergency Service
                    </h3>
                    <p class="text-base text-gray-600">
                        Available when you need us most
                    </p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"
                            ></path>
                            <path
                                fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3
                        class="text-xl font-heading font-bold text-primary mb-2"
                    >
                        Competitive Pricing
                    </h3>
                    <p class="text-base text-gray-600">
                        Free estimates with transparent pricing
                    </p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3
                        class="text-xl font-heading font-bold text-primary mb-2"
                    >
                        Satisfaction Guaranteed
                    </h3>
                    <p class="text-base text-gray-600">
                        We stand behind our work 100%
                    </p>
                </div>
            </div>

            <!-- CTA Section -->
            <CTA
                title="Ready to Get Started?"
                subtitle={`Take your ${trade.name.toLowerCase()} business online with a professional website. Contact us today for a free consultation.`}
                primaryCtaText="Get Free Quote"
                primaryCtaLink="/contact"
                secondaryCtaText="Browse Templates"
                secondaryCtaLink="/our-work"
            />
        </div>
    </section>
</BaseLayout>
