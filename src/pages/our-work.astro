---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import Button from "../components/ui/Button.astro";
import { getCollection } from "astro:content";

// Get all templates and trades
const allTemplates = await getCollection("templates");
const allTrades = await getCollection("trades");

// Sort trades by order
const sortedTrades = allTrades.sort((a, b) => a.data.order - b.data.order);

// Get template count and first 3 templates per trade for preview
const tradeData = sortedTrades.map((trade) => {
    const templates = allTemplates.filter(
        (t) => t.data.trade === trade.data.slug,
    );
    return {
        trade: trade.data,
        templateCount: templates.length,
        previewTemplates: templates.slice(0, 3), // Only first 3 for preview
    };
});
---

<BaseLayout
    title="Our Work | Your Company"
    description="Browse our portfolio of professional website templates organized by industry"
>
    <Hero2
        title="Our Work"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "OUR WORK" }]}
    />

    <!-- Trade Categories with Preview -->
    <section class="py-16 px-6 bg-background">
        <div class="max-w-7xl mx-auto space-y-16">
            {
                tradeData.map((data) => (
                    <div class="trade-section">
                        {/* Trade Header */}
                        <div class="flex items-center justify-between mb-8 pb-4 border-b-2 border-accent">
                            <div>
                                <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary mb-2">
                                    {data.trade.name}
                                </h2>
                                <p class="text-base text-gray-600">
                                    {data.trade.hoverDescription}
                                </p>
                            </div>
                            <div class="text-right">
                                <div class="text-4xl font-heading font-bold text-accent mb-1">
                                    {data.templateCount}
                                </div>
                                <div class="text-sm text-gray-600 uppercase font-heading font-bold">
                                    {data.templateCount === 1
                                        ? "Template"
                                        : "Templates"}
                                </div>
                            </div>
                        </div>

                        {/* Template Previews */}
                        {data.previewTemplates.length > 0 ? (
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-6">
                                {data.previewTemplates.map((template) => (
                                    <div class="bg-white shadow-md hover:shadow-xl transition-all duration-300 group">
                                        <div class="relative h-72 overflow-hidden bg-gray-200">
                                            <div class="absolute top-4 right-4 z-10">
                                                <span class="bg-accent text-white px-3 py-1 text-xs font-heading font-bold uppercase">
                                                    {template.data.category}
                                                </span>
                                            </div>
                                            <img
                                                src={template.data.thumbnail}
                                                alt={template.data.title}
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                            />
                                        </div>
                                        <div class="p-6">
                                            <h3 class="text-lg md:text-xl font-heading font-bold text-primary mb-2">
                                                {template.data.title}
                                            </h3>
                                            <p class="text-base text-gray-600 line-clamp-2">
                                                {template.data.description}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <div class="bg-gray-50 p-8 text-center mb-6">
                                <p class="text-base text-gray-600">
                                    Templates coming soon for this industry
                                </p>
                            </div>
                        )}

                        {/* View All Button */}
                        <div class="text-center">
                            <Button
                                variant="outline"
                                size="md"
                                href={`/trades-we-serve/${data.trade.slug}`}
                            >
                                View All {data.trade.name} Templates
                            </Button>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Why Choose Our Templates -->
    <section class="py-16 px-6 bg-white">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                    Why Choose Our Templates?
                </h2>
                <p class="text-base md:text-xl text-gray-600">
                    Built with your success in mind
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="font-heading font-bold text-base md:text-lg text-primary mb-2"
                    >
                        Mobile Optimized
                    </h3>
                    <p class="text-sm text-gray-600">Perfect on all devices</p>
                </div>
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3
                        class="font-heading font-bold text-base md:text-lg text-primary mb-2"
                    >
                        Fast Loading
                    </h3>
                    <p class="text-sm text-gray-600">Optimized performance</p>
                </div>
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="font-heading font-bold text-base md:text-lg text-primary mb-2"
                    >
                        Easy Customization
                    </h3>
                    <p class="text-sm text-gray-600">No coding required</p>
                </div>
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="font-heading font-bold text-base md:text-lg text-primary mb-2"
                    >
                        24/7 Support
                    </h3>
                    <p class="text-sm text-gray-600">Always here to help</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
