---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
---

<BaseLayout
    title="Trades We Serve | Your Company"
    description="Explore the different trades and services we offer"
>
    <Hero2
        title="Trades We Serve"
        backgroundImage="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&h=1080&fit=crop&q=80"
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE" },
        ]}
    />

    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                [
                    "Plumbing",
                    "Electrical",
                    "HVAC",
                    "Carpentry",
                    "Roofing",
                    "Masonry",
                ].map((trade) => (
                    <a
                        href={`/trades-we-serve/${trade.toLowerCase().replace(/\s+/g, "-")}`}
                        class="bg-white p-8 shadow-lg hover:shadow-xl transition-shadow cursor-pointer"
                    >
                        <h3 class="font-heading font-bold text-2xl mb-4 text-[var(--color-primary)]">
                            {trade}
                        </h3>
                        <p class="text-gray-600">
                            Professional {trade.toLowerCase()} services with
                            experienced technicians.
                        </p>
                    </a>
                ))
            }
        </div>
    </section>
</BaseLayout>
